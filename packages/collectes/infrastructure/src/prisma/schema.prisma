generator client {
  provider = "prisma-client-js"
  output   = "../../../../../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

model Collecte {
  id           String   @id
  nom          String
  statut       String
  dateCollecte DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("collectes")
}