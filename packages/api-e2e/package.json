{
  "name": "@collecte-2026/api-e2e",
  "version": "0.0.1",
  "private": true,
  "nx": {
    "implicitDependencies": [
      "@collecte-2026/api"
    ],
    "targets": {
      "e2e": {
        "executor": "@nx/jest:jest",
        "outputs": [
          "{projectRoot}/test-output/jest/coverage"
        ],
        "options": {
          "jestConfig": "packages/api-e2e/jest.config.cts",
          "passWithNoTests": true
        },
        "dependsOn": [
          "@collecte-2026/api:build",
          "@collecte-2026/api:serve"
        ]
      }
    }
  }
}
