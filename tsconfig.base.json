{
  "compilerOptions": {
    "composite": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "importHelpers": true,
    "isolatedModules": true,
    "lib": ["es2022"],
    "types": ["node"],
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "noEmitOnError": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "es2022",
    "paths": {
      "@collecte-2026/shared-kernel": ["./packages/shared/kernel/src/index.ts"],
      "@collecte-2026/collectes-domain": ["./packages/collectes/domain/src/index.ts"],
      "@collecte-2026/collectes-application": ["./packages/collectes/application/src/index.ts"],
      "@collecte-2026/collectes-infrastructure": [
        "./packages/collectes/infrastructure/src/index.ts"
      ]
    }
  }
}
